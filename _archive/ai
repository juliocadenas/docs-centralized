// -- Chat AI --
function ChatAITool() {
  const [messages, setMessages] = useState<Array<{role: string; content: string}>>([
    { role: 'assistant', content: '¡Hola! Soy tu IA local corriendo en la RTX 5080. ¿En qué puedo ayudarte?' }
  ]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const chatRef = useRef<HTMLDivElement>(null);

  const send = async () => {
    if (!input.trim() || loading) return;
    const userMsg = { role: 'user', content: input };
    setMessages(prev => [...prev, userMsg]);
    setInput('');
    setLoading(true);
    try {
      const content = await apiChat([...messages, userMsg]);
      setMessages(prev => [...prev, { role: 'assistant', content }]);
    } catch { setMessages(prev => [...prev, { role: 'assistant', content: 'Error conectando con el servidor.' }]); }
    setLoading(false);
    setTimeout(() => chatRef.current?.scrollTo(0, chatRef.current.scrollHeight), 100);
  };

  return (
    <div className="p-8 max-w-4xl mx-auto h-screen flex flex-col">
      <h1 className="text-2xl font-bold text-white mb-1">🤖 Chat con IA</h1>
      <p className="text-gray-400 text-sm mb-4">Llama 3.1 — Tu asistente local, zero tokens, sin límites</p>
      
      <div ref={chatRef} className="flex-1 overflow-y-auto space-y-3 mb-4 pr-2">
        {messages.map((m, i) => (
          <div key={i} className={`flex ${m.role === 'user' ? 'justify-end' : 'justify-start'}`}>
            <div className={`max-w-[80%] px-4 py-3 rounded-2xl text-sm whitespace-pre-wrap ${
              m.role === 'user' ? 'bg-purple-600/30 text-white' : 'bg-white/5 text-gray-200'}`}>
              {m.content}
            </div>
          </div>
        ))}
        {loading && <div className="text-gray-500 text-sm animate-pulse">● ● ●</div>}
      </div>
      
      <div className="flex gap-2">
        <input className="flex-1 bg-white/5 border border-white/10 rounded-xl p-3 text-white placeholder-gray-600 focus:border-purple-500 focus:outline-none"
          placeholder="Escribe tu mensaje..." value={input} onChange={e => setInput(e.target.value)}
          onKeyDown={e => e.key === 'Enter' && send()} />
        <button onClick={send} disabled={loading}
          className="px-6 py-3 rounded-xl font-bold bg-purple-600 hover:bg-purple-500 disabled:opacity-40 transition">
          Enviar
        </button>
      </div>
    </div>
  );
}

