    case 'slogan-gen': return <LLMTool title="Generador de Slogans" icon="💡" desc="Frases pegadizas para tu marca"
      systemPrompt="Eres un experto en branding. Genera 10 slogans creativos, pegadizos y memorables."
      placeholder="Describe tu marca o producto..."
      extraFields={[{ key: 'brand', label: 'Marca', placeholder: 'Nombre de la marca' }]} />;
    case 'video-effects': return <ComingSoonTool title="Efectos de Video" icon="⚡" desc="Efectos tipo Higgsfield — Cámara lenta, zoom cinemático, transiciones" />;
